{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Capability Registry",
  "type": "object",
  "required": ["capabilities"],
  "properties": {
    "schema": {
      "type": "string"
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "name", "path", "status", "tags"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]*$"
          },
          "type": {
            "type": "string",
            "enum": ["skill", "plugin", "mcp", "workflow", "agent", "prompt", "template", "doc"]
          },
          "name": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["candidate", "draft", "stable", "deprecated"]
          },
          "import_strategy": {
            "type": "string",
            "enum": ["imported", "reference", "index-only"]
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "description": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "entrypoint": {
            "type": "string"
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "inputs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "outputs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "secrets": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "last_verified": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "upstream": {
            "type": "object",
            "required": ["repo", "path", "commit", "last_checked"],
            "properties": {
              "repo": {
                "type": "string"
              },
              "url": {
                "type": "string"
              },
              "path": {
                "type": "string"
              },
              "commit": {
                "type": "string"
              },
              "last_checked": {
                "type": "string"
              },
              "notes": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
